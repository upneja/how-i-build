# Copy to secrets.env (gitignored) and fill. Do NOT commit real values.
# Point these at your own Twilio + email credentials. Never paste secrets into git.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=                     # your Twilio sender number, e.g. +1XXXXXXXXXX
NOTIFY_PHONE=                    # the ONLY number the agent talks to (your mobile)

PUBLIC_URL=                      # set after deploy, e.g. https://gtm-<slug>.up.railway.app
# STATE_PATH=./state.json        # override if your host has a writable volume elsewhere

# Local testing ONLY, bypasses Twilio signature checks. Never set in production.
# SKIP_TWILIO_VALIDATION=1
