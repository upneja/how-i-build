# Copy to config.env (gitignored) and fill. The engine reads creds in place from the
# files you point at below, so no secrets ever live in this repo.

SMS_TO=                 # your phone in E.164, e.g. +1XXXXXXXXXX
EMAIL_TO=               # where to email the digest
DIGEST_PUSH=critical    # critical = send only on a new critical action | all | off

# Paths to files that hold your provider credentials (KEY=VALUE lines). Reuse whatever
# you already have; the engine just reads these keys out of them:
TWILIO_ENV=             # a file with TWILIO_ACCOUNT_SID, TWILIO_AUTH_TOKEN, TWILIO_FROM
GMAIL_ENV=              # a file with GMAIL_ADDRESS, GMAIL_APP_PASSWORD
